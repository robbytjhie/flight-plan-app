# Copy to terraform.tfvars (git-ignored) and fill in real values.
# NEVER commit terraform.tfvars — secrets must come from Secrets Manager or CI env vars.

aws_region            = "ap-southeast-1"
environment           = "staging"                      # or "prod"
app_image_tag         = "develop-abc1234"              # set by CI
domain_name           = "api-stg.flightplan.example.io"
acm_certificate_arn   = "arn:aws:acm:ap-southeast-1:123456789012:certificate/..."
cors_allowed_origins  = "https://app-stg.flightplan.example.io"
desired_count         = 2
task_cpu              = 512
task_memory           = 1024
